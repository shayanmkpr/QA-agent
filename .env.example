# LLM provider: "openai", "openrouter", or "local"
LLM_PROVIDER=local

# --- Local (used when LLM_PROVIDER=local) ---
LOCAL_MODEL=something
LOCAL_BASE_URL=http://192.168.91.101:8004/v1
LOCAL_API_KEY=z2kWL1rmaE4BdvJqMOX23JOocE3s3tZiM

# --- OpenRouter ---
OPENROUTER_API_KEY=sk-or-...
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# --- OpenAI (used when LLM_PROVIDER=openai) ---
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=

# --- Tool calling ---
# TOOL_CHOICE=required  # uncomment if your backend rejects "auto" (use "required" not "any")

# --- Storage backend ---
# json = CSV + JSON files (default)
# sqlite = relational database (data/qa_agent.db)
STORAGE_BACKEND=json

# --- VLM comparison ---
INCLUDE_HTML_IN_VLM=true  # set to "false" to exclude HTML text from vision comparison requests
