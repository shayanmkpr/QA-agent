# LLM provider: "openai" or "openrouter"
LLM_PROVIDER=openrouter

# --- OpenRouter ---
OPENROUTER_API_KEY=sk-or-...
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# --- OpenAI (used when LLM_PROVIDER=openai) ---
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=

# --- Tool calling ---
# TOOL_CHOICE=required  # uncomment if your backend rejects "auto" (use "required" not "any")

# --- VLM comparison ---
INCLUDE_HTML_IN_VLM=true  # set to "false" to exclude HTML text from vision comparison requests
